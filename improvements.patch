+++ b/src/main/java/com/ai/assistant/controller/LearningController.java
@@
+package com.ai.assistant.controller;
+
+import com.ai.assistant.model.*;
+import com.ai.assistant.service.LearningService;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.http.ResponseEntity;
+import org.springframework.web.bind.annotation.*;
+
+import java.util.List;
+
+@RestController
+@RequestMapping("/api/learning")
+public class LearningController {
+
+    @Autowired
+    private LearningService service;
+
+    @PostMapping("/ask")
+    public ResponseEntity<String> ask(@RequestBody QuestionRequest req) {
+        return ResponseEntity.ok(service.processQuestion(req.getQuestion()));
+    }
+
+    @PostMapping("/assess")
+    public ResponseEntity<Integer> assess(@RequestBody AnswerRequest req) {
+        return ResponseEntity.ok(service.evaluate(req.getAnswer()));
+    }
+
+    @GetMapping("/path/{userId}")
+    public ResponseEntity<List<String>> path(@PathVariable String userId) {
+        return ResponseEntity.ok(service.getLearningPath(userId));
+    }
+}
diff --git a/src/main/java/com/ai/assistant/service/LearningService.java b/src/main/java/com/ai/assistant/service/LearningService.java
new file mode 100644
--- /dev/null
+++ b/src/main/java/com/ai/assistant/service/LearningService.java
@@
+package com.ai.assistant.service;
+
+import com.ai.assistant.agent.GapDetectorAgent;
+import com.ai.assistant.agent.TutorAgent;
+import com.ai.assistant.rag.RagService;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.stereotype.Service;
+
+import java.util.Arrays;
+import java.util.List;
+
+@Service
+@Slf4j
+public class LearningService {
+
+    @Autowired
+    private TutorAgent tutorAgent;
+
+    @Autowired
+    private GapDetectorAgent gapAgent;
+
+    @Autowired
+    private RagService ragService;
+
+    public String processQuestion(String question) {
+        log.info("Processing question: {}", question);
+        String context = ragService.answerWithRAG(question);
+        return tutorAgent.execute(context);
+    }
+
+    public int evaluate(String answer) {
+        String response = tutorAgent.execute("Score out of 10:\n" + answer);
+        return Integer.parseInt(response.replaceAll("\\D", ""));
+    }
+
+    public List<String> getLearningPath(String userId) {
+        String gaps = gapAgent.execute("User history: " + userId);
+        return Arrays.asList(gaps.split("\\n"));
+    }
+}
